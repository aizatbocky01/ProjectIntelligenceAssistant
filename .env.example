# =============================================================
# Project Intelligence Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# =============================================================

# --- LLM Provider ---
# Choose 'ollama' for local models or 'gemini' for Google cloud
LLM_PROVIDER=ollama

# --- Ollama Settings (used when LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# --- Google Gemini Settings (used when LLM_PROVIDER=gemini) ---
GOOGLE_API_KEY=your_gemini_api_key_here

# --- Qdrant Vector DB ---
# Leave as defaults to use local file-based storage (no Docker needed)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_VECTOR_SIZE=768
