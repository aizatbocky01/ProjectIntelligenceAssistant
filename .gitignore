.venv/
venv/
env/
ENV/

# --- Node / Frontend ---
node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Qdrant Local Storage ---
data/qdrant_storage/
qdrant_storage/

# --- Logs ---
logs/
*.log

# --- OS & IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Misc ---
*.lock
.langgraph_api/
data/